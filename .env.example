# AquaVerse 환경변수 예시
# cp .env.example .env 후 값 수정

# Registry
REGISTRY=cashyalla.synology.me:50002
VERSION=latest

# PostgreSQL
POSTGRES_DB=aquaverse
POSTGRES_USER=aquaverse
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_256BIT_RANDOM_SECRET

# MinIO (S3 Compatible Storage)
MINIO_ACCESS_KEY=aquaverse_admin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Push Notifications
FCM_SERVER_KEY=AAAA...

# Email (SendGrid)
SENDGRID_API_KEY=SG.xxx...

# OAuth (선택)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
